{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "efficient-build": {
      "description": "Efficient subagent for building and testing code. Executes tasks with minimal token usage.",
      "mode": "subagent"
    }
  },
  "plugin": [
    "opencode-browser"
  ],
  "mcp": {
    "browsermcp": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@browsermcp/mcp@0.1.3"
      ],
      "enabled": true
    }
  }
}
